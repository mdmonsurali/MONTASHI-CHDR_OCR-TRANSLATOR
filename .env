# Chandra-OCR-2 runtime configuration. Loaded automatically by `docker compose`.
# Override any value here without rebuilding the image.

# OCR model. CHANDRA_MODEL is the HF repo baked into the image at build time;
# OCR_MODEL_NAME is the served-model id vLLM advertises and the client requests.
CHANDRA_MODEL=datalab-to/chandra-ocr-2
OCR_MODEL_NAME=chandra
# HuggingFace token, only needed at BUILD time if the model repo is gated.
HF_TOKEN=

# Ports (host -> container)
OCR_SERVICE_PORT=8001
UI_SERVICE_PORT=8000
VLLM_PORT=8888

# GPU 
# Which physical GPU each service uses, e.g. "0", "1", "2".
# On a single-GPU host, leave TRANSLATOR_GPU_DEVICE_ID equal to GPU_DEVICE_ID
# and shrink GPU_MEM_UTIL so both models fit; on a multi-GPU host, give each
GPU_DEVICE_ID=0
TRANSLATOR_GPU_DEVICE_ID=0

# VLLM_MAX_NUM_SEQS is AUTO-DETECTED from GPU memory at container start (see
# [probe] line in `docker logs ocr_service`). The others are static defaults
# here; override any value to suit your GPU.
#
# Fraction of GPU memory vLLM may consume (0.0-1.0). Single-GPU hosts share the
# card with translator_service (OCR runs while translator is stopped and vice
# versa, via the orchestrator GPU swap), so this is tuned to use most of the
# active GPU. MAX_MODEL_LEN bounds the context window; Chandra's default output
# budget is ~12k tokens (OCR_MAX_TOKENS), so 16k of context is ample headroom.
GPU_MEM_UTIL=0.60
MAX_MODEL_LEN=16384
VLLM_MAX_NUM_SEQS=8

# OCR batching (pages in flight to vLLM per file)
# Native (text-extractable) PDFs and DOCX: high throughput
OCR_BATCH_SIZE_NATIVE=16
# Scanned PDFs / image inputs: lower because each page is a vision-heavy call
OCR_BATCH_SIZE_SCANNED=4
# Fallback when type cannot be detected
OCR_BATCH_SIZE=2

# vLLM request cap
# Max output tokens per page. Must be < MAX_MODEL_LEN (vLLM enforces this).
# Chandra's default output budget is 12384.
OCR_MAX_TOKENS=12384

# Repeat-loop guard: how many times to retry a page (with rising temperature)
# when the model degenerates into a repeated token sequence. Replaces
# Unlimited-OCR's ngram logits processor.
OCR_MAX_RETRIES=6

# Formula rendering style
FORMULA_SIZE_MULTIPLIER=1.6
FORMULA_BOLD=true

# Picture / figure handling 
INCLUDE_PICTURES=true

# Per-entry font/size/bold/italic/color attribution.
ATTRIBUTE_STYLES=true

# Postgres (metadata store)
POSTGRES_DB=ocr
POSTGRES_USER=ocr
POSTGRES_PASSWORD=changeme

# MinIO (object store) 
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=changeme
MINIO_BUCKET=ocr
MINIO_REGION=us-east-1
MINIO_SECURE=false
MINIO_CONSOLE_PORT=9001
# Max simultaneous PUTs per document (decoupled from OCR_BATCH_SIZE_*).
MINIO_UPLOAD_CONCURRENCY=8

# Auth service
AUTH_SERVICE_PORT=8002

MASTER_USERNAME=master
MASTER_PASSWORD=changeme-please
# How long a login lasts before the user must sign in again.
SESSION_TTL_HOURS=12
# Set to true when the UI is served over HTTPS (sets the Secure cookie flag).
COOKIE_SECURE=false

# Translator service (llama.cpp Gemma 3 12B Q4_K_M) 
LLAMA_CTX_SIZE=8192
LLAMA_PARALLEL=2
TRANSLATE_CONCURRENCY=2

# Orchestrator service 
GPU_SWAP=true

# How long the orchestrator waits for a container's healthcheck to go
# llama.cpp Gemma loads 30-90s.
SWAP_HEALTH_TIMEOUT_SEC=300
