# Unlimited-OCR runtime configuration. Loaded automatically by `docker compose`.
# Override any value here without rebuilding the image.

# Ports (host -> container)
OCR_SERVICE_PORT=8001
UI_SERVICE_PORT=8000
VLLM_PORT=8888

# GPU 
# Which physical GPU each service uses, e.g. "0", "1", "2".
# On a single-GPU host, leave TRANSLATOR_GPU_DEVICE_ID equal to GPU_DEVICE_ID
# and shrink GPU_MEM_UTIL so both models fit; on a multi-GPU host, give each
GPU_DEVICE_ID=0
TRANSLATOR_GPU_DEVICE_ID=0

# The four knobs below are AUTO-DETECTED from GPU memory at container start
# (see [probe] line in `docker logs ocr_service`). Leave blank to use the
# tier defaults, or set a value to override.
#
# Unlimited-OCR caps max_model_len at 32768 (max_position_embeddings).
# Larger GPUs get more concurrency, not longer context.
#
#   GPU memory       | tier         | mem_util | model_len | num_seqs | max_tok
#   <= 12 GiB (T4)   | small        | 0.85     | 8192      | 2        | 6000
#   <= 18 GiB (L4)   | medium-small | 0.75     | 16384     | 4        | 14000
#   <= 26 GiB (A10G) | medium       | 0.60     | 32768     | 8        | 30000
#   <= 50 GiB (A100) | large        | 0.55     | 32768     | 16       | 30000
#   > 50 GiB (H100)  | xlarge       | 0.50     | 32768     | 32       | 30000

# Fraction of GPU memory vLLM may consume (0.0-1.0). Blank → tier default.
# Single-GPU shared with translator_service: lowered from 0.60 to 0.50 to
# leave ~11 GB for Gemma 12B Q4_K_M weights + KV cache.
# OCR gets the full GPU; translator_service is stopped while OCR runs and
# vice versa (see translator-mode.sh). Both services tuned to use most of
# the 23 GB A10G when they're the active one.
# Unlimited-OCR's config.json has max_position_embeddings=32768 — vLLM
# refuses to boot with MAX_MODEL_LEN above that.
GPU_MEM_UTIL=0.60
MAX_MODEL_LEN=32768
VLLM_MAX_NUM_SEQS=8

# OCR batching (pages in flight to vLLM per file)
# Native (text-extractable) PDFs and DOCX: high throughput
OCR_BATCH_SIZE_NATIVE=16
# Scanned PDFs / image inputs: lower because each page is a vision-heavy call
OCR_BATCH_SIZE_SCANNED=4
# Fallback when type cannot be detected
OCR_BATCH_SIZE=2

# vLLM request cap 
# Max output tokens per page. Must be < MAX_MODEL_LEN (vLLM enforces this).
# Unlimited-OCR caps at 32768; leave ~2k headroom for the prompt.
OCR_MAX_TOKENS=30000

# Unlimited-OCR image config 
# Two image preprocessing modes (per upstream HF Space):
#   base    = 1024 px, no crop → ACCURATE / "Long" model (default; better quality)
#   gundam  =  640 px, crop on → FAST / lower-res (lower VRAM and latency)
OCR_IMAGE_MODE=base

# Formula rendering style
FORMULA_SIZE_MULTIPLIER=1.6
FORMULA_BOLD=true

# Picture / figure handling 
INCLUDE_PICTURES=true

# Per-entry font/size/bold/italic/color attribution.
ATTRIBUTE_STYLES=true

# Postgres (metadata store)
POSTGRES_DB=ocr
POSTGRES_USER=ocr
POSTGRES_PASSWORD=changeme

# MinIO (object store) 
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=changeme
MINIO_BUCKET=ocr
MINIO_REGION=us-east-1
MINIO_SECURE=false
MINIO_CONSOLE_PORT=9001
# Max simultaneous PUTs per document (decoupled from OCR_BATCH_SIZE_*).
MINIO_UPLOAD_CONCURRENCY=8

# Auth service
AUTH_SERVICE_PORT=8002

MASTER_USERNAME=master
MASTER_PASSWORD=changeme-please
# How long a login lasts before the user must sign in again.
SESSION_TTL_HOURS=12
# Set to true when the UI is served over HTTPS (sets the Secure cookie flag).
COOKIE_SECURE=false

# Translator service (llama.cpp Gemma 3 12B Q4_K_M) 
LLAMA_CTX_SIZE=8192
LLAMA_PARALLEL=2
TRANSLATE_CONCURRENCY=2

# Orchestrator service 
GPU_SWAP=true

# How long the orchestrator waits for a container's healthcheck to go
# llama.cpp Gemma loads 30-90s.
SWAP_HEALTH_TIMEOUT_SEC=300
